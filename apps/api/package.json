{
  "name": "@parenting-newsletter/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node --env-file=../../.env --import tsx --watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "node --import tsx src/index.ts",
    "pipeline:daily": "node --env-file=../../.env --import tsx src/cli-daily.ts",
    "pipeline:publish": "node --env-file=../../.env --import tsx src/cli-publish.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "tsx": "^4.0.0",
    "@parenting-newsletter/agents-core": "workspace:*",
    "@parenting-newsletter/agent-research": "workspace:*",
    "@parenting-newsletter/agent-curation": "workspace:*",
    "@parenting-newsletter/agent-writer": "workspace:*",
    "@parenting-newsletter/agent-editor": "workspace:*",
    "@parenting-newsletter/agent-hooking": "workspace:*",
    "@parenting-newsletter/db": "workspace:*",
    "@parenting-newsletter/shared": "workspace:*",
    "hono": "^4.12.25"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3"
  }
}
