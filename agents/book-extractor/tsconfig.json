{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],
    "outDir": "./dist",
    "paths": {
      "@parenting-newsletter/agents-core": ["../../packages/agents-core/src"],
      "@parenting-newsletter/db": ["../../packages/db/src"],
      "@parenting-newsletter/shared": ["../../packages/shared/src"]
    }
  },
  "include": ["src/**/*.ts", "schema.ts"],
  "exclude": ["node_modules", "dist"]
}
