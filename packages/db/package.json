{
  "name": "@parenting-newsletter/db",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "node --env-file=.env --import tsx prisma/seed.ts",
    "db:backup": "node --env-file=.env --import tsx scripts/backup.ts",
    "db:restore": "node --env-file=.env --import tsx scripts/restore.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "@parenting-newsletter/shared": "workspace:*"
  },
  "devDependencies": {
    "prisma": "^5.0.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.3",
    "tsx": "^4.0.0"
  }
}
