// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")    // 런타임 — pgbouncer pooler 사용
  directUrl = env("DIRECT_URL")      // prisma migrate — pooler 우회
}

// 뉴스 기사 (URL + 자체 요약·본문만 저장, 원문 전문 저장 금지)
// 타입 정의는 packages/shared/src/article.ts 와 동기화 유지
model Article {
  id                  String    @id @default(cuid())
  title               String
  summary             String    @db.Text
  body                String    @db.Text       // 카드뉴스 본문 (## 헤딩 + - 불릿 형식)
  url                 String
  category            String                   // Category: policy|parenting|academy|play|shows|books|market
  contentType         String                   // ContentType: Policy|Event|Market|Insight|Guide
  mediaType           String?                  // text|video|podcast|book (미지정 시 text)
  durationMin         Int?                     // video/podcast 한정 — 분 단위
  source              String
  publishedAt         DateTime
  credibilityScore    Float     @default(0.0)
  issueDate           DateTime                 // 페런트웹 발행일 (Issue 식별자)
  eventStartDate      DateTime?                // Event 한정 — 이벤트 시작일
  eventEndDate        DateTime?                // Event 한정 — 이벤트 종료일 (시작일과 별개, 다일 행사)
  deadline            DateTime?                // 신청·접수 마감일
  tags                String[]
  imageUrl            String?
  dateCheck           Json?                    // 날짜 검증 결과(qa v0): 원문 재호출해 deadline/event 날짜 실재 확인. { checkedAt, fetchOk, deadline?, eventStartDate?, eventEndDate? : 'verified'|'unconfirmed' }

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  issues              IssueArticle[]
  agentLogs           AgentLog[]

  // 같은 발행일에 동일 원문 URL 중복 적재 방지 (curation 재실행 멱등성). SPEC §6.3
  @@unique([issueDate, url])
  @@index([category])
  @@index([contentType])
  @@index([issueDate])
  @@index([eventStartDate])
  @@index([eventEndDate])
  @@index([deadline])
  @@index([createdAt])
  @@index([url])
}

// 예약 가능 시설 — packages/shared/src/venue.ts 와 동기화 유지
model ReservableVenue {
  id                  String    @id            // venue-* slug 그대로 사용
  name                String
  type                String                   // VenueType: museum|show|library|indoor-play|program
  ageRange            String                   // 권장 연령. "0-7" / "3-12" 형식
  entryMinAge         Int?                     // 실 입장 가능 최소 연령
  region              String                   // "서울 용산구" — 첫 토큰이 REGIONS 중 하나
  reservationUrl      String
  reservationChannel  String                   // 운영주체명
  operator            String                   // VenueOperator: national|metro|district
  pricing             String                   // Pricing: free|paid|mixed
  schedule            String?
  description         String    @db.Text
  credibilityScore    Float     @default(0.0)
  tags                String[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([type])
  @@index([region])
  @@index([operator])
  @@index([pricing])
}

// 도서 컬렉션 — 기사에서 추출한 추천 도서를 기사 만료와 무관하게 보존하는 에버그린 엔티티.
// ReservableVenue 선례: Article과 하드 FK 없이 독립 + 느슨 연결(sourceArticleIds). SPEC §12.
// packages/shared/src/book.ts 와 동기화 유지.
model Book {
  id                  String    @id            // book-* slug (ISBN 기반 권장)
  isbn                String?                  // ISBN13 — 알라딘·정보나루 enrichment 키
  title               String
  author              String
  publisher           String?
  pubYear             Int?
  ageRange            String                   // "3-7" venue와 동일 포맷
  coverImageUrl       String?                  // 알라딘 표지(enrichment). 없으면 카테고리 폴백
  whyRecommended      String    @db.Text       // ★ 우리 큐레이션 — 왜 추천(세일링 보이스)
  themes              String[]                 // 테마 태그
  collection          String                   // 컬렉션 묶음명 "2026년 5월 그림책 10선"
  collectionDate      String                   // YYYY-MM (정렬·그룹 키)
  links               Json?                    // BookLink[]: 도서관(정보나루)·구매(제휴)
  sourceArticleIds    String[]                 // 출처 기사 역링크
  credibilityScore    Float     @default(0.0)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([collection])
  @@index([collectionDate])
  @@index([isbn])
}

// 일일 이슈 (MVP는 웹 전용 — 이메일 필드는 V2 착수 시 재추가, SPEC §7-D)
model DailyIssue {
  id                  String    @id @default(cuid())
  issueDate           DateTime  @unique
  status              String    @default("draft")  // 발행 게이트: draft(검토 전·비공개) | published(공개). 신규 이슈는 항상 draft, 운영자가 검수 후 published로 flip.
  title               String?              // 그날의 한 줄 후킹 (hooking ← cardHook)
  summary             String?   @db.Text   // 그날의 짧은 요약 (hooking ← homeCopy)
  theme               String?              // 오늘의 테마 (editor가 설정)

  articles            IssueArticle[]
  agentLogs           AgentLog[]

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([issueDate])
  @@index([status])
}

// 이슈에 포함된 기사들
model IssueArticle {
  id                  String    @id @default(cuid())
  issueId             String
  issue               DailyIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  
  articleId           String
  article             Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  
  // 에디터 에이전트가 작성한 커스텀 제목과 설명
  customTitle         String?
  customDescription   String?    @db.Text
  order               Int        @default(0) // 기사 순서
  
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@unique([issueId, articleId])
  @@index([issueId])
  @@index([articleId])
}

// 에이전트 실행 로그 및 파이프라인 추적
model AgentLog {
  id                  String    @id @default(cuid())
  issueId             String
  issue               DailyIssue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  
  agentName           String    // research, curation, editor, hooking
  articleId           String?
  article             Article?   @relation(fields: [articleId], references: [id], onDelete: SetNull)
  
  status              String    @default("pending") // pending, processing, success, failed
  input               Json?     // 에이전트 입력
  output              Json?     // 에이전트 출력
  errorMessage        String?   @db.Text
  
  processingTimeMs    Int?      // 처리 시간
  
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([issueId])
  @@index([agentName])
  @@index([status])
  @@index([createdAt])
}

// 에이전트 설정 및 프롬프트 버전 관리
model AgentConfig {
  id                  String    @id @default(cuid())
  name                String    @unique // research, curation, editor, hooking
  version             Int       @default(1)
  prompt              String    @db.Text
  schema              String    @db.Text // JSON 스키마
  isActive            Boolean   @default(true)

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

// 이메일 구독자 — 식별 데이터 최소(부모 신원만, 아동 PII 0).
// email = 나중 소셜 로그인 연결 다리(authUserId 빈칸 → 첫 로그인 시 이메일 매칭으로 link).
model Subscriber {
  id          String    @id @default(cuid())
  email       String    @unique            // 구독 이메일 = 식별·연결 키
  consent     Boolean   @default(true)      // 구독·수신 동의
  consentAt   DateTime  @default(now())
  source      String?                       // 유입 지점 (home_cta / reservation 등)
  anonId      String?                       // 익명 이벤트 흐름과 연결
  authUserId  String?   @unique             // 2-② 소셜 로그인 연결용 (지금은 null)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([anonId])
  @@index([createdAt])
}

// 세일링 레터 — 주간 뉴스레터. 발송 전 초안(sentAt=null), 발송 후 아카이브.
model Letter {
  id          String       @id @default(cuid())
  slug        String       @unique           // URL slug (예: 2026-06-24)
  subject     String                         // 이메일 제목 = 아카이브 타이틀
  previewText String?                        // 이메일 미리보기 텍스트 (~50자)
  editorNote  String?      @db.Text          // 에디터 메시지·인트로 (마크다운, 선택)
  sentAt      DateTime?                      // null = 초안
  sentCount   Int          @default(0)
  items       LetterItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([sentAt])
}

// 레터 내 아티클 — 카테고리별 큐레이션 아이템.
// articleId: 파이프라인 Article과 연결 가능(선택). 없으면 독립 콘텐츠(마이그레이션 등).
model LetterItem {
  id          String   @id @default(cuid())
  letterId    String
  letter      Letter   @relation(fields: [letterId], references: [id], onDelete: Cascade)
  order       Int                            // 레터 내 표시 순서 (0-based)
  category    String                         // 섹션명 (손과 감각 / 관계와 언어 / 세상과 미래 / 뇌와 실패 / 놀이와 자연 등 자유 문자열)
  title       String                         // 대제목
  subtitle    String?                        // 소제목 (선택)
  body        String   @db.Text             // 본문 마크다운
  quote       String?                        // 핵심 인용구 (선택)
  url         String?                        // 원문 링크 (선택)
  articleId   String?                        // 파이프라인 Article 참조 (선택)

  @@index([letterId, order])
}

// 익명 분석 이벤트 — PII 0(익명 기기 난수만). CTA·페이지뷰·전환 측정.
model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String                           // page_view | cta_impression | cta_click | cta_dismiss | subscribe_success ...
  anonId    String                           // 익명 기기 난수 (개인정보 아님)
  path      String?                          // 발생 화면 경로
  meta      Json?                            // 부가 정보 (cta 위치 등)
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([anonId])
}
