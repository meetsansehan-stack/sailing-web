# ─── Supabase ────────────────────────────────────────────────
# DB·인증 모두 Supabase 사용. supabase.com 프로젝트 생성 후 Settings → API/Database에서 값 복사.

# Prisma용 PostgreSQL 연결 (Supabase → Settings → Database → Connection string → URI, "Connection pooling" 사용 시 Transaction mode 권장)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# prisma migrate용 직접 연결 (pooler 우회) — Direct connection URI
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# Supabase 클라이언트 키 (apps/web, apps/api에서 사용)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."
SUPABASE_SERVICE_ROLE_KEY="eyJ..."   # 서버 전용 — 클라이언트에 노출 금지

# ─── 서버 ────────────────────────────────────────────────
API_PORT=3001
API_URL="http://localhost:3001"
CORS_ALLOWED_ORIGINS="http://localhost:3000"

# 발행 게이트 — 미공개(draft) 이슈를 운영자가 미리보기 할 때 쓰는 비밀 토큰.
# 사이트 URL에 ?preview=<이 값> 을 붙이면 draft까지 보임. 비워두면 미리보기 비활성(공개분만).
# 길고 추측 어려운 임의 문자열 권장 (예: openssl rand -hex 16).
PREVIEW_TOKEN=""

# 운영(admin) API 토큰 — 파이프라인·에이전트·QA 트리거, 구독 삭제 등 비용·뮤테이션
# 엔드포인트 보호. 호출 시 `Authorization: Bearer <이 값>`. **fail-closed**: 미설정이면
# 해당 엔드포인트는 전부 503으로 거부(실수로 무인증 노출 방지). 배포 환경엔 반드시 설정.
# (cli-daily 등 로컬 데일리 흐름은 함수 직접 호출이라 이 토큰 불필요.)
# 예: openssl rand -hex 24.
ADMIN_API_TOKEN=""

# ─── 웹 ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL="http://localhost:3001"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Claude AI API — 둘 중 하나만 채우면 됨
#  (1) API 키: console.anthropic.com 선불 크레딧 (카드 필요)
CLAUDE_API_KEY="sk-ant-..."
#  (2) 구독 OAuth: `claude setup-token`으로 발급 (Pro/Max, 카드 불필요).
#      이 토큰을 쓸 땐 위 CLAUDE_API_KEY는 placeholder로 비워둘 것 (API 키가 OAuth를 덮어씀).
CLAUDE_CODE_OAUTH_TOKEN=""

# Redis (캐싱, 선택사항)
REDIS_URL="redis://localhost:6379"

# Agent Configuration
AGENT_TIMEOUT_MS=30000
AGENT_MAX_RETRIES=3

# Pipeline Schedule (KST)
PIPELINE_RESEARCH_TIME="00:00"
PIPELINE_CURATION_TIME="01:00"
PIPELINE_EDITOR_TIME="02:00"
PIPELINE_HOOKING_TIME="03:00"

# ─── Naver 수요 발굴 (Demand Mining) ─────────────────────────
# 검색광고 키워드도구(절대 검색량) — searchad.naver.com → 도구 → API 사용 관리 (사업자 광고주)
NAVER_AD_CUSTOMER_ID=""
NAVER_AD_API_KEY=""        # 액세스라이선스
NAVER_AD_SECRET_KEY=""     # 비밀키 (발급 시 1회만 노출)
# 데이터랩 검색어트렌드(연령·시즌) — developers.naver.com → 애플리케이션 등록 (검색어트렌드 API)
NAVER_DATALAB_CLIENT_ID=""
NAVER_DATALAB_CLIENT_SECRET=""

# ─── 도서 컬렉션 enrichment (packages/db/scripts/enrich-books.ts) ───
# 알라딘 TTB — 표지·메타·구매(제휴) 링크. https://blog.aladin.co.kr/openapi
ALADIN_TTB_KEY=""
# 도서관 정보나루(선택) — 도서관 소장·대출 확인. https://www.data4library.kr
DATA4LIBRARY_KEY=""
DATA4LIBRARY_LIB_CODE=""          # 기준 도서관 코드 (예: 우리동네 대표관)
LIBRARY_URL_TEMPLATE=""           # 도서관 검색 링크 템플릿, {isbn} 치환

# 데일리 파이프라인 크론 (API 서버 내장). true 로 설정해야 활성화.
# Railway 운영 서버에만 true — 로컬·테스트는 false(또는 미설정).
PIPELINE_CRON_ENABLED="false"

# Environment
NODE_ENV="development"

# 에이전트별 모델 개별 오버라이드 (선택). 미지정 시 packages/agents-core/src/models.ts 기본값 사용.
# 값 = claude-opus-4-8 | claude-sonnet-4-6. A/B·비용조정용.
# MODEL_RESEARCH=
# MODEL_CURATION=
# MODEL_WRITER=
# MODEL_EDITOR=
# MODEL_HOOKING=
# MODEL_QA=
